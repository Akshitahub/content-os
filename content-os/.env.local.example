# ============================================================
# SocioPosts environment variables
#
# Copy this file to .env.local and fill in real values there.
# .env.local (and every other .env* file except this example) is
# gitignored — never commit real secrets. See README.md for what to do
# if a real secret was ever accidentally committed in the past.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are exposed to
# the browser by design (the NEXT_PUBLIC_ prefix) — this is only safe
# because Row Level Security is enabled on every table (see
# supabase/migrations/*.sql). Never disable RLS on a table without adding
# an equivalent server-side check.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS entirely — server-side only
# (lib/supabase/server.ts's createAdminClient). NEVER prefix this with
# NEXT_PUBLIC_ or reference it from a "use client" component.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI generation (Groq) — server-side only ─────────────────
GROQ_API_KEY=

# ── NVIDIA NIM — server-side only, never expose to client ───
# Get yours at https://build.nvidia.com — free tier available, no credit card required.
# Models used: extraction (llama-3.1-8b), generation (nemotron-70b), scoring (llama-3.3-70b)
NVIDIA_API_KEY=

# Image generation uses Pollinations.AI (https://pollinations.ai) — completely free, no API key needed.

# ── Background removal — server-side only ────────────────────
REMOVE_BG_API_KEY=

# ── Kling AI — server-side only, never expose to client ──────
# Powers real AI video reel generation (lib/video/kling-client.ts). Not yet
# obtained — reel video generation returns a clear "not configured" error
# until this is set. See that file's header comment for provider options
# (direct Kling API vs. an aggregator like PiAPI/fal.ai).
KLING_API_KEY=

# ── Zernio — unified social publishing API, server-side only ─
# Powers LinkedIn/YouTube/Twitter publishing (Pro/Agency plans).
ZERNIO_API_KEY=

# ── Meta (Instagram/Facebook) OAuth — server-side only ───────
META_APP_ID=
META_APP_SECRET=
META_LOGIN_CONFIG_ID=

# ── Pinterest OAuth — server-side only ────────────────────────
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# ── Threads OAuth — server-side only ──────────────────────────
THREADS_APP_ID=
THREADS_APP_SECRET=

# ── Razorpay billing ───────────────────────────────────────────
# RAZORPAY_KEY_ID is safe to return to the client (it's the equivalent of
# Stripe's publishable key, used to open the Razorpay checkout widget) —
# see app/api/v1/billing/create-checkout-session/route.ts. It is still kept
# as a server-side env var here rather than NEXT_PUBLIC_ since the server
# is the one that hands it to the client per-request.
# RAZORPAY_KEY_SECRET must NEVER be sent to the client — used only for
# order creation and HMAC signature verification.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Separate secret for the server-to-server webhook (Razorpay Dashboard ->
# Settings -> Webhooks -> set the URL to <your-domain>/api/v1/billing/webhook,
# subscribe to payment.captured, and copy the secret it gives you here — it
# is NOT the same value as RAZORPAY_KEY_SECRET). Without this set, the
# webhook route fails closed with a clear "not configured" error rather than
# silently accepting unverified requests.
RAZORPAY_WEBHOOK_SECRET=

# ── Cron authentication — server-side only ────────────────────
# Shared secret for app/api/v1/cron/* routes (Vercel Cron sends this as a
# Bearer token or ?secret= query param).
CRON_SECRET=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend (transactional email) — server-side only ───────────
RESEND_API_KEY=

# ── PostHog (analytics) ────────────────────────────────────────
# Public by design — PostHog's client-side key is meant to be exposed.
NEXT_PUBLIC_POSTHOG_KEY=
